# ── Auth mode / persistence ───────────────────────────────────────────────
# local    = Dexie/IndexedDB in the browser (no server needed — single-device).
# api      = Deno backend with Deno.Kv (SQLite-backed file on disk, server-side
#            persistence shared across browsers/devices). Recommended for real
#            usage. Start with: `npm run dev:full` (or `npm run dev:server`).
# supabase = Hosted Postgres via Supabase (cross-device + cross-machine).
VITE_AUTH_MODE=api

# Used when VITE_AUTH_MODE=api — points at the local Deno server.
VITE_API_URL=http://localhost:8000

# ── Supabase (only when VITE_AUTH_MODE=supabase) ──────────────────────────
# 1) Create a project at supabase.com
# 2) Run server/supabase/schema.sql in Supabase Studio → SQL editor
# 3) Paste your project's URL + public anon key below
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GIPHY_API_KEY=
VITE_PIXABAY_KEY=
VITE_PEXELS_KEY=
VITE_UNSPLASH_KEY=
VITE_TENOR_KEY=
VITE_FREESOUND_TOKEN=

# Phase B — Jamendo full CC tracks (devportal.jamendo.com client_id)
VITE_JAMENDO_CLIENT_ID=

# Phase C — Spotify Now Playing (OAuth PKCE; redirect /oauth/spotify/callback)
VITE_SPOTIFY_CLIENT_ID=
# Dev-only: Spotify track search in Links tab (server-side client credentials)
SPOTIFY_CLIENT_SECRET=

# Strava recent activities (personal access token from strava.com/settings/api)
VITE_STRAVA_ACCESS_TOKEN=

# Image search: Wikimedia (no key) + optional Pixabay / Pexels / Unsplash via /wall-img-api proxy:
# VITE_PIXABAY_KEY=  VITE_PEXELS_KEY=  VITE_UNSPLASH_KEY=  VITE_GIPHY_API_KEY=

# Backend (Deno) — only when VITE_AUTH_MODE=api
# Run: cd server && deno run --allow-all main.ts
JWT_SECRET=change-me-in-production
FRONTEND_ORIGIN=http://localhost:5173
PORT=8000

# Wall Agent AI (server-side only — never expose to browser)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Cloud switch (future) ─────────────────────────────────────────────────
# Point VITE_AUTH_MODE=api and VITE_API_URL at your deployed API, or replace
# server KV with Supabase/Postgres in docker-compose without changing the app.
