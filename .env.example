# ── Auth mode ─────────────────────────────────────────────────────────────
# local = Dexie/IndexedDB in the browser (default, no server needed)
# api   = Deno backend at VITE_API_URL (Deno KV; swap docker/env for Supabase later)
VITE_AUTH_MODE=local

# Frontend (Vite) — leave empty for fully local dev
VITE_API_URL=
VITE_GIPHY_API_KEY=
VITE_UNSPLASH_KEY=
VITE_PEXELS_KEY=
VITE_TENOR_KEY=
VITE_FREESOUND_TOKEN=

# Backend (Deno) — only when VITE_AUTH_MODE=api
# Run: cd server && deno run --allow-all main.ts
JWT_SECRET=change-me-in-production
FRONTEND_ORIGIN=http://localhost:5173
PORT=8000

# Wall Agent AI (server-side only — never expose to browser)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Cloud switch (future) ─────────────────────────────────────────────────
# Point VITE_AUTH_MODE=api and VITE_API_URL at your deployed API, or replace
# server KV with Supabase/Postgres in docker-compose without changing the app.
