    "lucide-react": "^1.16.0",
    "nanoid": "^5.1.11",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.15.1",
    "tailwind-merge": "^3.6.0",
    "tldraw": "^5.0.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
